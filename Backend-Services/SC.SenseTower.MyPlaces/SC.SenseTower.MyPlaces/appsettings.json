{
  "MongoDbConfig": {
    "ConnectionString": "mongodb://host.docker.internal:27017/?tls=true&tlsInsecure=true",
    "DatabaseName": "MyPlaces"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IS4Configuration": {
    "Authority": "http://localhost:64820/",
    "ClientId": "vr",
    "Audience": "IS4API"
  },
  "HttpConnectionSettings": {
    "MaxAttempts": 6,
    "BreakAfter": 4,
    "BreakForSeconds": 60
  },
  "ServiceEndpointsSettings": {
    "AccountsRootUrl": "https://localhost:44325/",
    "AccountsGetInfoUrl": "userinfo/getinfo",
    "AccountsLookupUrl": "userinfo/lookup",
    "AuthRootUrl": "http://localhost:64820/",
    "ImagesRootUrl": "",
    "ImagesGetByIds": "images/get",
    "ImagesConnectWithPlace": "images/ConnectWithPlace",
    "SpacesRootUrl": "https://localhost:44310/",
    "GetSpaceUrl": "spaces/{0}",
    "GetSpacesByIdsUrl": "spaces/byids",
    "HallsRootUrl": "https://localhost:44320/api/v1/",
    "HallsUpdatePlaceUrl": "updateuserplace",
    "HallsDeletePlaceUrl": "clearuserplaces"
  },
  "RabbitMQConnectionSettings": {
    "HostName": "localhost",
    "Port": -1,
    "UserName": "guest",
    "Password": "guest",
    "Exchanges": [
      "DefaultExchange"
    ]
  },
  "UserDeleteBindingSettings": {
    "Exchange": "DefaultExchange",
    "RoutingKey": "identity.users.delete",
    "Type": "topic",
    "AutoAck": true,
    "IsSynchronously": false
  },
  "SpaceDeleteBindingSettings": {
    "Exchange": "DefaultExchange",
    "RoutingKey": "tower.spaces.delete",
    "Type": "topic",
    "AutoAck": true,
    "IsSynchronously": false
  },
  "SpaceUpdateBindingSettings": {
    "Exchange": "DefaultExchange",
    "RoutingKey": "tower.spaces.update",
    "Type": "topic",
    "AutoAck": true,
    "IsSynchronously": false
  }
}
