{
  "MongoDbConfig": {
    "ConnectionString": "mongodb://host.docker.internal:27017/?tls=true&tlsInsecure=true",
    "DatabaseName": "Halls"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IS4Configuration": {
    "Authority": "http://localhost:64820/",
    "ClientId": "vr",
    "Audience": "IS4API"
  },
  "HttpConnectionSettings": {
    "MaxAttempts": 6,
    "BreakAfter": 4,
    "BreakForSeconds": 60
  },
  "ServiceEndpointsSettings": {
    "MyPlacesRootUrl": "https://localhost:44305/api/v1/myplaces/",
    "MyPlacesByIdsUrl": "user/places",
    "SpacesRootUrl": "https://localhost:44310/api/v1/",
    "GetSpaceUrl": "spaces/{0}",
    "ImagesRootUrl": "https://localhost:44380/api/v1/",
    "ImagesByIdsUrl": "images/get"
  },
  "RabbitMQConnectionSettings": {
    "HostName": "localhost",
    "Port": -1,
    "UserName": "guest",
    "Password": "guest"
  },
  "UserDeleteBindingSettings": {
    "Exchange": "DefaultExchange",
    "RoutingKey": "identity.users.delete",
    "Type": "topic",
    "AutoAck": true,
    "IsSynchronously": false
  },
  "UserPlaceUpdateBindingSettings": {
    "Exchange": "DefaultExchange",
    "RoutingKey": "tower.places.update",
    "Type": "topic",
    "AutoAck": true,
    "IsSynchronously": false
  },
  "SpaceUpdateBindingSettings": {
    "Exchange": "DefaultExchange",
    "RoutingKey": "tower.spaces.update",
    "Type": "topic",
    "AutoAck": true,
    "IsSynchronously": false
  },
  "SpaceDeleteBindingSettings": {
    "Exchange": "DefaultExchange",
    "RoutingKey": "tower.spaces.delete",
    "Type": "topic",
    "AutoAck": true,
    "IsSynchronously": false
  },
  "PlacesDeleteBindingSettings": {
    "Exchange": "DefaultExchange",
    "RoutingKey": "tower.places.delete",
    "Type": "topic",
    "AutoAck": true,
    "IsSynchronously": false
  }
}
