@using SC.SenseTower.Accounts.Constants
@inject IConfiguration configuration
@model RegisterByTicketViewModel
@{
    var staticRootUrl = configuration[ConfigKeys.STATIC_ROOT_URL];
}
<div class="row mt-5">
    <div class="col-xs-12 col-sm-8 col-md-6 col-lg-4 offset-sm-2 offset-md-3 offset-lg-4">
        <div class="card w-100">
            <form method="post" action="byticket">
                <div class="card-body">
                    <h5 class="card-title">Регистрация по гостевому приглашению</h5>
                    <div asp-validation-summary="All" class="text-danger"></div>
                    @if (ViewBag.Message != null)
                    {
                        <div class="p-1 mb-2 bg-success text-white">@ViewBag.Message</div>
                    }
                    <div class="form-group">
                        <label asp-for="TicketId"></label>
                        <input type="text" class="form-control" readonly asp-for="TicketId" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Login"></label>
                        <input type="text" class="form-control" asp-for="Login" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Email"></label>
                        <input type="email" class="form-control" asp-for="Email" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Password"></label>
                        <div class="input-group">
                            <input type="password" class="form-control" asp-for="Password" />
                            <button type="button" class="btn btn-outline-secondary eye-button"><i class="fas fa-eye"></i></button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="ConfirmPassword"></label>
                        <div class="input-group">
                            <input type="password" class="form-control" asp-for="ConfirmPassword" />
                            <button type="button" class="btn btn-outline-secondary eye-button"><i class="fas fa-eye"></i></button>
                        </div>
                    </div>
                    @if (ViewBag.Message == null)
                    {
                        <button type="submit" class="btn btn-primary mt-2">Регистрация</button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script type="text/javascript" charset="utf-8" src="@(staticRootUrl)js/passwords.js"></script>
}
