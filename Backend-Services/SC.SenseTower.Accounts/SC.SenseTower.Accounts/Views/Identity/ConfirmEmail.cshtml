@{
    var userId = (Guid)ViewBag.UserId;
    var code = (string)ViewBag.Code;
}
<div class="container-fluid">
    <div class="row mt-5">
        <div class="col-xs-12 col-md-8 col-lg-6 offset-md-2 offset-lg-3">
            <div class="card w-100">
                <form method="post">
                    <div class="card-body">
                        <p>
                            Вы зарегистрировались в метавселенной <b>SenseTower</b>!<br/>
                            Для полноценного использования всех её возможностей необходимо подтведить ваш регистрационный email.
                            Нажмите кнопку подтверждения ниже.
                        </p>
                        <input type="hidden" name="userId" value="@userId.ToString()" />
                        <input type="hidden" name="code" value="@code" />
                        <button type="submit" class="btn btn-primary mt-2">Подтвердить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>