@using SC.SenseTower.Accounts.Constants
@inject IConfiguration configuration
@model ResetPasswordViewModel
@{
    var staticRootUrl = configuration[ConfigKeys.STATIC_ROOT_URL];
}
<div class="row mt-5">
    <div class="col-xs-12 col-sm-8 col-md-6 col-lg-4 offset-sm-2 offset-md-3 offset-lg-4">
        <div class="card w-100">
            <form method="post">
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Token" />
                <div class="card-body">
                    <h5 class="card-title">Изменение пароля</h5>
                    <div asp-validation-summary="All" class="text-danger"></div>
                    <div class="form-group">
                        <label asp-for="Password"></label>
                        <div class="input-group">
                            <input type="password" class="form-control" asp-for="Password" />
                            <button type="button" class="btn btn-outline-secondary eye-button"><i class="fas fa-eye"></i></button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="ConfirmPassword"></label>
                        <div class="input-group">
                            <input type="password" class="form-control" asp-for="ConfirmPassword" />
                            <button type="button" class="btn btn-outline-secondary eye-button"><i class="fas fa-eye"></i></button>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary mt-2">Изменить пароль</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script type="text/javascript" charset="utf-8" src="@(staticRootUrl)js/passwords.js"></script>
}
