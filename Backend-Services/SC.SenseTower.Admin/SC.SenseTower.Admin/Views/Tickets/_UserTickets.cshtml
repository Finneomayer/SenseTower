@using AutoMapper
@using SC.SenseTower.Admin.Models.Tickets
@inject IMapper mapper
@model UserTicketsViewModel
@{
    var items = mapper.Map<SelectListItem[]>(Model.AvailableUsers);
}
<div class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <form method="post">
                <div class="modal-header">
                    <h5 class="modal-title font-weight-normal">@Model.Title</h5>
                    <button type="button" class="btn-close text-dark" data-bs-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="input-group input-group-static my-3">
                        <label class="ms-0" asp-for="UserId"></label>
                        <select class="form-control" asp-for="UserId" asp-items="items"></select>
                    </div>
                    <div class="input-group input-group-static mb-3">
                        <label class="ms-0" asp-for="Quantity"></label>
                        <input type="number" class="form-control" asp-for="Quantity" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn bg-gradient-primary"><i class="fas fa-check"></i> Выдать</button>
                </div>
            </form>
        </div>
    </div>
</div>
