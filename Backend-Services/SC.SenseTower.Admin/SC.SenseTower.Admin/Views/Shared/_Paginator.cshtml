@using SC.SenseTower.Admin.Dto
@model PaginationDto
@{
    var visibleCount = 5;
    var startPage = Model.CurrentPage <= visibleCount ? 1 : Model.CurrentPage - visibleCount + 1;
    if (startPage < 1)
    {
        startPage = 1;
    }
    var finishPage = Math.Max(1, Math.Min(Model.TotalPages, startPage + visibleCount - 1));
    var nextPage = Math.Min(Model.CurrentPage + 1, Model.TotalPages);
    var prevPage = Math.Max(1, Model.CurrentPage - 1);
    var sizes = new int[] { 10, 25, 50, 100, 300 };
}
<nav class="navbar navbar-expand d-flex justify-content-between">
    <ul class="navbar-nav justify-content-end">
        <li class="nav-item">
            <ul class="pagination">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" tabindex="-1" data-page="1"><i class="fas fa-angle-double-left"></i></a>
                </li>
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" tabindex="-1" data-page="@Math.Max(1, Model.CurrentPage - 1)"><i class="fas fa-angle-left"></i></a>
                </li>
                @if (startPage > 1)
                {
                    <li class="page-item align-middle">
                        <i class="fas fa-ellipsis-h my-2"></i>
                    </li>
                }
                @for (var pageNumber = startPage; pageNumber <= finishPage; pageNumber++)
                {
                    <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="javascript:;" data-page="@pageNumber">@pageNumber</a>
                    </li>
                }
                @if (finishPage < Model.TotalPages)
                {
                    <li class="page-item align-middle">
                        <i class="fas fa-ellipsis-h my-2"></i>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" tabindex="-1" data-page="@Math.Min(Model.TotalPages, Model.CurrentPage + 1)"><i class="fas fa-angle-right"></i></a>
                </li>
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" tabindex="-1" data-page="@Model.TotalPages"><i class="fas fa-angle-double-right"></i></a>
                </li>
            </ul>
        </li>
        <li class="nav-item mx-2">
            <div class="input-group input-group-static mt-n1">
                <select class="form-control">
                    @foreach (var size in sizes)
                    {
                        if (size == Model.PageSize)
                        {
                            <option value="@size" selected>@size</option>
                        }
                        else
                        {
                            <option value="@size">@size</option>
                        }
                    }
                </select>
            </div>
        </li>
@*        <li class="nav-item mx-2">
            <div class="mt-1">
                Элементов на странице <span>@Model.CurrentCount из @Model.TotalCount</span>
            </div>
        </li>*@
    </ul>
    <div>
        Элементов на странице <span>@Model.CurrentCount из @Model.TotalCount</span>
    </div>
</nav>
