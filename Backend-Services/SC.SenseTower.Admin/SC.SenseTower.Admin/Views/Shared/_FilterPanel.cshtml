@model object
<div class="fixed-plugin">
    <a class="fixed-plugin-button text-dark position-fixed px-3 py-2">
        <i class="material-icons py-2">filter_alt</i>
    </a>
    <div class="card shadow-lg" id="filter-panel">
        <div class="card-header pb-0 pt-3">
            <div class="float-start">
                <h5 class="mt-3 mb-0">Фильтр</h5>
                <p>Фильтрация списка.</p>
            </div>
            <div class="float-end mt-4">
                <button class="btn btn-link text-dark p-0 fixed-plugin-close-button">
                    <i class="material-icons">clear</i>
                </button>
            </div>
        </div>
        <hr class="horizontal dark my-1">
        <div class="card-body pt-sm-3 pt-0">
            <partial name="_Filters" model="Model" />
            <button type="button" class="btn btn-icon btn-primary mt-3" id="apply-filter">
                <span class="btn-inner--icon"><span class="material-icons">check</span></span>
                <span class="btn-inner--text">Применить</span>
            </button>
            <button type="button" class="btn btn-icon btn-secondary mt-3" id="clear-filter">
                <span class="btn-inner--icon"><span class="material-icons">clear</span></span>
                <span class="btn-inner--text">Очистить</span>
            </button>
        </div>
    </div>
</div>
