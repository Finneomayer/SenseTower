@using SC.SenseTower.Admin.Models.Users
@model UserBanViewModel
<div class="modal fade" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title font-weight-normal">Блокировка пользователя</h5>
                <button type="button" class="btn-close text-dark" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form method="post">
                <div class="modal-body">
                    <input type="hidden" asp-for="UserId" />
                    <div class="row mb-3">
                        <div class="col-6">
                            <div class="input-group input-group-static">
                                <label class="ms-0" asp-for="LockoutEnd">Блокировка по</label>
                                <input type="datetime-local" class="form-control" asp-for="LockoutEnd">
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-check mt-3">
                                <input class="form-check-input" type="checkbox" asp-for="IsPermanent">
                                <label class="custom-control-label" asp-for="IsPermanent">Бессрочно</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn bg-gradient-primary"><i class="fas fa-ban"></i> Блокировать</button>
                </div>
            </form>
        </div>
    </div>
</div>