  _closeButtonText:
    LocalizationKey: close-button
    DefaultValue: "\u0417\u0430\u043A\u0440\u044B\u0442\u044C"
  _successText:
    LocalizationKey: manager-call-soon
    DefaultValue: "\u0412\u0430\u0448\u0430 \u0437\u0430\u044F\u0432\u043A\u0430
      \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0430 \u043C\u0435\u043D\u0435\u0434\u0436\u0435\u0440\u0443
      \u0438 \u0432 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
      \u043E\u043D \u0441 \u0412\u0430\u043C\u0438 \u0441\u0432\u044F\u0436\u0435\u0442\u0441\u044F"
  _failNameValidation:
    LocalizationKey: fail-name
    DefaultValue: "\u0417\u0430\u043F\u043E\u043B\u043D\u0438\u0442\u0435 \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E
      \u043F\u043E\u043B\u0435 \u0438\u043C\u0435\u043D\u0438"
  _emptyNameError:
    LocalizationKey: empty-name-error
    DefaultValue: "\u0412\u044B \u043D\u0435 \u0432\u0432\u0435\u043B\u0438 \u0438\u043C\u044F"
  _emptyEmailError:
    LocalizationKey: email-fail
    DefaultValue: "\u0412\u044B \u043D\u0435 \u0432\u0432\u0435\u043B\u0438 email"
  _failPhoneNumberError:
    LocalizationKey: phone-number-fail
    DefaultValue: "\u0412\u044B \u0432\u0432\u0435\u043B\u0438 \u043D\u0435\u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u044B\u0439
      \u043D\u043E\u043C\u0435\u0440 \u0442\u0435\u043B\u0435\u0444\u043E\u043D\u0430"
  _failText:
