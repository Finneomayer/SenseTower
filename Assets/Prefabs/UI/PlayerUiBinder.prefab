--- !u!114 &6534944872633898240
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 8431037444968443966}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: db35976d2cbcb374cbede8789a67a12c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _uiBinder: {fileID: 6380596892410420070}
  _keyboard: {fileID: 2785907373303788073}
  _modalWindow: {fileID: 8534586308511401735}
  _registrationInSwitcherMenuBtn: {fileID: 4056395782467938516}
  _registrationBtn: {fileID: 7446967145595018172}
  _closeBtn: {fileID: 8911949177531297186}
  _closeSuccessBtn: {fileID: 691544961741502334}
  _notificationText: {fileID: 8560794692038840207}
  _inputFields: {fileID: 2561596074464509785}
  _successText: {fileID: 2280624617088028287}
  _loginInput: {fileID: 7912847284104360348}
  _emailInput: {fileID: 19789851409945050}
  _passwordInput: {fileID: 8863081047190629569}
  _confirmPasswordInput: {fileID: 1883758648954395486}
  _fillAllFieldsLocalizationVariant:
    LocalizationKey: empty-input-field-error
    DefaultValue: "\u041D\u0435 \u0432\u0441\u0435 \u043F\u043E\u043B\u044F \u0437\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u044B"
  _passwordsMissmatchLocalizationVariant:
    LocalizationKey: password-no-equals-error
    DefaultValue: "\u041F\u0430\u0440\u043E\u043B\u0438 \u043D\u0435 \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u044E\u0442"
  _sceneNeedsToRestartLocalizationVariant:
    LocalizationKey: notifiaction-ready-to-restart
    DefaultValue: "\u0414\u0430\u043D\u043D\u044B\u0435 \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u044B.
      \u0421\u0435\u0439\u0447\u0430\u0441 \u0431\u0443\u0434\u0435\u0442 \u043F\u0435\u0440\u0435\u0437\u0430\u0433\u0440\u0443\u0436\u0435\u043D\u043E
      \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E"
  _authErrorLocalizationVariant:
    LocalizationKey: notification-authorisation-error
    DefaultValue: "\u041F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430 \u043E\u0448\u0438\u0431\u043A\u0430
      \u0430\u0432\u0442\u043E\u0440\u0438\u0437\u0430\u0446\u0438\u0438, \u043E\u0431\u0440\u0430\u0442\u0438\u0442\u0435\u0441\u044C
      \u043A \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440\u0443"
  _endMainingTWRLocalizationVariant:
    LocalizationKey: 50twr-end-maining-text
    DefaultValue: "\u0412\u044B \u043F\u0440\u043E\u0431\u044B\u043B\u0438 \u0432
      \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0433\u043E\u0441\u0442\u044F
      \u0432 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0438 50 \u043C\u0438\u043D\u0443\u0442
      \u0438 \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438 50 TWR.
      \u0412 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0433\u043E\u0441\u0442\u044F
      \u0432\u044B \u0431\u043E\u043B\u0435\u0435 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442\u0435
      \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C TWR. \u0414\u043B\u044F \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u044F
      \u0443\u0436\u0435 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u044B\u0445
      TWR \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438
      \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C \u043D\u043E\u0432\u044B\u0435
      \u0441\u043E\u0432\u0435\u0442\u0443\u0435\u043C \u0412\u0430\u043C \u0437\u0430\u0440\u0435\u0433\u0438\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C\u0441\u044F
      \u0432 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0438"
  _registrationCongratulationLocalizationVariant:
    LocalizationKey: notification-successfull-registration
    DefaultValue: "\u041F\u043E\u0437\u0434\u0440\u0430\u0432\u043B\u044F\u0435\u043C!
      \u0412\u044B \u0437\u0430\u0440\u0435\u0433\u0438\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
      \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044C"
  _currentEarnedLocalizationVariant:
    LocalizationKey: twr-earned-guest
    DefaultValue: "\u0417\u0430 \u0432\u0440\u0435\u043C\u044F \u043F\u0440\u0435\u0431\u044B\u0432\u0430\u043D\u0438\u044F
      \u0432 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0438 \u0412\u044B
      \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438 {0} TWR. \u0414\u043B\u044F
      \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u044F \u0443\u0436\u0435
      \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u044B\u0445 TWR \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438
      \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C \u043D\u043E\u0432\u044B\u0435
      \u0441\u043E\u0432\u0435\u0442\u0443\u0435\u043C \u0412\u0430\u043C \u0437\u0430\u0440\u0435\u0433\u0438\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C\u0441\u044F
      \u0432 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0438"
